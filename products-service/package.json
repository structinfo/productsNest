{
  "name": "products-service",
  "version": "0.0.1",
  "description": "NestJS products microservice with Sequelize and MySQL",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\" \"*.{json,md}\"",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "docker:build": "DOCKER_BUILDKIT=1 docker build -t products-service:latest .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env --name products-service products-service:latest",
    "docker:run:detached": "docker run -d -p 3000:3000 --env-file .env --name products-service products-service:latest",
    "docker:stop": "docker stop products-service",
    "docker:logs": "docker logs -f products-service",
    "docker:clean": "docker rm -f products-service",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "keywords": [],
  "author": "Vladimir Korobov",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mysql2": "^3.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.16",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
